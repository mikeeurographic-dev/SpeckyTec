<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Guides & PDFs</title>
  
  <!-- Netlify Identity Widget -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  
  <!-- Decap CMS (formerly Netlify CMS) -->
  <script src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
</head>
<body>
  <script>
    window.netlifyIdentity = window.netlifyIdentity || {};
    window.netlifyIdentity.on("init", user => {
      if (!user) {
        window.netlifyIdentity.open();
      }
    });
  </script>
</body>
</html>
admin/config.yml

backend:
  name: git-gateway
  branch: main        # change to "master" if your default branch is master

publish_mode: editorial_workflow

media_folder: "assets/uploads"   # folder where uploaded PDFs will go
public_folder: "/assets/uploads"

collections:
  - name: "guides"
    label: "Guides & PDFs"
    folder: "guides"
    create: true
    slug: "{{year}}-{{month}}-{{day}}-{{slug}}"
    fields:
      - {label: "Title", name: "title", widget: "string"}
      - {label: "Date", name: "date", widget: "datetime"}
      - {label: "Category", name: "category", widget: "string"}
      - {label: "PDF File", name: "pdf", widget: "file", allow_multiple: false}
      - {label: "Description", name: "description", widget: "text"}
